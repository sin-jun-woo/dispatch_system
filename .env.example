# Docker Compose 기본값 (docker-compose.yml 에서 대부분 자동 주입)
# 처음 실행 전 복사: cp .env.example .env  (Windows: copy .env.example .env)

# DB — 컨테이너 내부에서는 mysql 호스트명 사용
DATABASE_URL=mysql://dispatch:dispatch_dev@mysql:3306/dispatch_system

# JWT (기사 세션 서명)
JWT_SECRET=change-me-to-a-long-random-string

PORT=3000
NODE_ENV=development

# manus 플랫폼 (사진 업로드 등, 없으면 업로드 기능만 실패)
VITE_APP_ID=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
